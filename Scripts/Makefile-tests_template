.SUFFIXES:

all : 	$(MODSOBJ) $(PROGDIR)main.F90
	$(COMPILER) $(COMPFLAGS) $(PROGDIR)main.F90
	$(COMPILER) -o ./main.out main.o $(MODSOBJ) $(LIBS)
	rm main.o

install : main.out
	if test ! -d $(INSTDIR); then mkdir -p $(INSTDIR); fi
	mv ./main.out $(INSTDIR)
	cp $(TESTDIR)state.cdf.in$(TESTCASE) $(INSTDIR)state.cdf.in
	echo $(HOST) > $(INSTDIR)/main.info
	date >> $(INSTDIR)/main.info
	echo $(COMPILER) $(COMPFLAGS) >> $(INSTDIR)/main.info
	grep define parallel.h | grep 'e _Nth' >> $(INSTDIR)/main.info
	grep define parallel.h | grep 'e _Nr' >> $(INSTDIR)/main.info
	cut -d! -f1 $(PROGDIR)parameters.F90 | grep parameter | \
	   cut -d: -f3  >> $(INSTDIR)/main.info

test : main.out
	if test ! -d $(INSTDIR); then mkdir -p $(INSTDIR); fi
	mv ./main.out $(INSTDIR)
	cp $(TESTDIR)state.cdf.in $(INSTDIR)state.cdf.in
	echo $(HOST) > $(INSTDIR)/main.info
	date >> $(INSTDIR)/main.info
	echo $(COMPILER) $(COMPFLAGS) >> $(INSTDIR)/main.info
	grep define parallel.h | grep 'e _Nth' >> $(INSTDIR)/main.info
	grep define parallel.h | grep 'e _Nr' >> $(INSTDIR)/main.info
	cut -d! -f1 $(TESTDIR)parameters$(TESTCASE).F90 | grep parameter | \
	   cut -d: -f3  >> $(INSTDIR)/main.info

util : 	$(MODSOBJ) $(UTILDIR)/$(UTIL).F90
	$(COMPILER) $(COMPFLAGS) $(UTILDIR)/$(UTIL).F90
	$(COMPILER) -o ./$(UTIL).out $(UTIL).o $(MODSOBJ) $(LIBS)
	rm $(UTIL).o

#------------------------------------------------------------------------
clean :
	rm -f *.o *.mod *.d *.il core *.out; rm $(AUXLDIR)*.o

#------------------------------------------------------------------------
parameters.o : $(TESTDIR)parameters$(TESTCASE).F90 parallel.h
	$(COMPILER) $(COMPFLAGS) -o parameters.o $(TESTDIR)parameters$(TESTCASE).F90

io.o : $(PROGDIR)io.F90 velocity.o codensity.o
	if [[ -f $(LIBSDIR)/NETCDF.mod && ! -f ./NETCDF.mod ]] ; then\
	  ln -s $(LIBSDIR)/NETCDF.mod . ; fi
	if [[ -f $(LIBSDIR)/netcdf.mod && ! -f ./netcdf.mod ]] ; then\
	  ln -s $(LIBSDIR)/netcdf.mod . ; fi
	$(COMPILER) $(COMPFLAGS) $(PROGDIR)io.F90

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
codensity.o : $(MODSDIR)codensity.F90 timestep.o transform.o
	$(COMPILER) $(COMPFLAGS) $(MODSDIR)codensity.F90

composition.o : $(MODSDIR)composition.F90 timestep.o transform.o
	$(COMPILER) $(COMPFLAGS) $(MODSDIR)composition.F90

legendre.o : $(MODSDIR)legendre.F90 parameters.o dyn_mpi.o
	$(COMPILER) $(COMPFLAGS) $(MODSDIR)legendre.F90

magnetic.o : $(MODSDIR)magnetic.F90 timestep.o transform.o
	$(COMPILER) $(COMPFLAGS) $(MODSDIR)magnetic.F90

meshs.o : $(MODSDIR)meshs.F90 parameters.o dyn_mpi.o
	$(COMPILER) $(COMPFLAGS) $(MODSDIR)meshs.F90

dyn_mpi.o : $(MODSDIR)dyn_mpi.F90 parallel.h
	$(COMPILER) $(COMPFLAGS) $(MODSDIR)dyn_mpi.F90

nonlinear.o : $(MODSDIR)nonlinear.F90 \
	velocity.o codensity.o
	$(COMPILER) $(COMPFLAGS) $(MODSDIR)nonlinear.F90

rotation.o : $(MODSDIR)rotation.F90 timestep.o transform.o
	$(COMPILER) $(COMPFLAGS) $(MODSDIR)rotation.F90

timestep.o : $(MODSDIR)timestep.F90 variables.o
	$(COMPILER) $(COMPFLAGS) $(MODSDIR)timestep.F90

transform.o : $(MODSDIR)transform.$(TRANSFORM).F90 variables.o
	$(COMPILER) $(COMPFLAGS) -o transform.o \
	$(MODSDIR)transform.$(TRANSFORM).F90

variables.o : $(MODSDIR)variables.F90 legendre.o meshs.o
	$(COMPILER) $(COMPFLAGS) $(MODSDIR)variables.F90

velocity.o : $(MODSDIR)velocity.F90 timestep.o transform.o rotation.o
	$(COMPILER) $(COMPFLAGS) $(MODSDIR)velocity.F90

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -

$(AUXLDIR)%.o : $(AUXLDIR)%.f
	$(COMPILER) $(COMPFLAGS) -o $@ $<

