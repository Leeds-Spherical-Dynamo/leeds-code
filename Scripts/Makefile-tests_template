#COMPFLAGS = -O1 -c -cpp -qmkl=sequential\
#                   -I${SHTNS_HOME}/include/
#LIBS = -lnetcdf -lnetcdff -lfftw3 -qmkl=sequential\
#                   -L${SHTNS_HOME}/lib/ -lshtns

#----------------------Aire-gnu----------------------------------------
# Load cemac module environment using `. /users/cemac/cemac.sh`
# Then load required modules, 
# > module load gnu mvpich atlas netcdf hdf5 fftw
# submission script should source the cemac.sh and then load the modules
