TESTDIR  = ./tests/
TESTCASE = -case$(CASE)
INSTDIR  = ./test_run/test$(TESTCASE)/
AUXLDIR  = ./auxiliary/
MODSDIR  = ./modules/
PROGDIR  = ./program/
UTILDIR  = ./utils/
UTIL     = ash2cont

TRANSFORM  = fftw3
_AUXLOBJ   = dplm.o dpmm1.o dpmm.o fftw3.o gauwts.o plm.o pmm1.o pmm.o schnla.o
AUXLOBJ    = $(patsubst %,$(AUXLDIR)%,$(_AUXLOBJ))
MODSOBJ    = $(AUXLOBJ) \
             codensity.o legendre.o meshs.o dyn_mpi.o composition.o\
             velocity.o magnetic.o rotation.o nonlinear.o parameters.o \
             timestep.o transform.o variables.o io.o
VER := $(shell grep define ./version.h | grep "_version" | cut -f3 -d' ')
version := $(patsubst "%",%,$(VER))
#------------------------------------------------------------------------
# Compiler flags/settings.
#
# Below are a series of example compiler settings for different environments.
# We have included example settings for ARC4 (the HPC at Leeds University),
# ARCHER2 national HPC facility, and settings for a generic workstation/laptop
# linux installation.
# Please uncomment the settings for your use case. For the HPC's, we've included
# guidance on what modules should be loaded in the environment.
#---------------------------------------------------------------------------

#----------------------------------- -------------------------------------
#------------------------- ARCHER2---------------------------------------
#
# Leave all of the default modules, and add the following 'required modules'
#
# Required modules: cray-fftw/3.3.8.9 cray-hdf5-parallel
# cray-netcdf-hdf5parallel gnuplot
#------------------------------------------------------------------------
