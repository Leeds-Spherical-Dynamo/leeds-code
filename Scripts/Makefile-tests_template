#COMPILER = ${MPIF90}
#COMPFLAGS = -c -cpp -O2\
#                   -I${SHTNS_HOME}/include/
#LIBS = -llapack -lf77blas -lcblas -latlas -lnetcdff -lnetcdf -lm -lfftw3 -lgfortran\
